# Impact Flow Environment Configuration
# Copy this file to .env.production for production deployment

# ============================================================================
# PostgreSQL Database
# ============================================================================
POSTGRES_USER=impactflow_user
POSTGRES_PASSWORD=STRONG_PASSWORD_HERE
POSTGRES_DB=impactflow_db

# ============================================================================
# Backend API Configuration
# ============================================================================
PORT=2001
NODE_ENV=production

# Security Secret (REQUIRED - Generate with: openssl rand -base64 48)
SESSION_SECRET=SECRET_PASSWORD

# CORS & Frontend URL (Use your production domain)
FRONTEND_URL=https://impact-flow.cora-branch.com

# Session Settings
SESSION_DURATION_HOURS=24
SESSION_CLEANUP_INTERVAL_MINUTES=60

# Rate Limiting
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# Frontend Configuration
# ============================================================================
VITE_API_URL=https://impact-flow.cora-branch.com/api

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=info
