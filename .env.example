# Impact Flow Environment Configuration
# Copy this file to .env and update with your values

# ============================================================================
# PostgreSQL Database
# ============================================================================
POSTGRES_USER=impactflow_user
POSTGRES_PASSWORD=secure_password_change_this
POSTGRES_DB=impactflow_db

# ============================================================================
# Backend API Configuration
# ============================================================================
PORT=2001
NODE_ENV=development

# Security Secrets (MUST change in production!)
SESSION_SECRET=change-this-to-a-random-32-char-string-minimum
API_KEY_ENCRYPTION_SECRET=change-this-to-another-random-string-for-encryption

# CORS & Frontend
FRONTEND_URL=http://localhost:2080

# Session Settings
SESSION_DURATION_HOURS=24
SESSION_CLEANUP_INTERVAL_MINUTES=60

# Rate Limiting
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# Frontend Configuration
# ============================================================================
VITE_API_URL=http://localhost:2001/api

# ============================================================================
# Optional: Logging
# ============================================================================
LOG_LEVEL=info
