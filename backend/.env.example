# Database Configuration
# In production, this is set via docker-compose environment variables
DATABASE_URL=postgresql://impactflow_user:password@postgres:5432/impactflow_db

# Server Configuration
PORT=2001
NODE_ENV=production

# Security (REQUIRED - Generate with: openssl rand -base64 48)
SESSION_SECRET=CHANGE_THIS_TO_RANDOM_STRING

# CORS Settings (Frontend URL - use your production domain)
FRONTEND_URL=http://localhost:2080

# Session Settings
SESSION_DURATION_HOURS=24
SESSION_CLEANUP_INTERVAL_MINUTES=60

# Rate Limiting
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
