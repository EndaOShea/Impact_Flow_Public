# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/impactflow
# Example: postgresql://impactflow_user:secure_password_here@localhost:5432/impactflow_db

# Server Configuration
PORT=2001
NODE_ENV=development

# Security
SESSION_SECRET=your-super-secret-random-string-min-32-chars-change-this-in-production
API_KEY_ENCRYPTION_SECRET=another-super-secret-random-string-for-api-key-encryption

# CORS Settings (Frontend URL)
FRONTEND_URL=http://localhost:3000

# Session Settings
SESSION_DURATION_HOURS=24
SESSION_CLEANUP_INTERVAL_MINUTES=60

# Rate Limiting
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
