{
  "name": "impact-flow-backend",
  "version": "1.0.0",
  "description": "Backend API for Impact Flow Task Manager with PostgreSQL",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:setup": "node scripts/setup-db.js",
    "db:migrate": "psql $DATABASE_URL -f database/schema.sql",
    "db:seed": "node scripts/seed-db.js",
    "db:reset": "node scripts/reset-db.js"
  },
  "keywords": ["task-management", "postgresql", "rest-api"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "compression": "^1.7.4",
    "hash-wasm": "^4.11.0",
    "cookie-parser": "^1.4.6",
    "uuid": "^9.0.1",
    "validator": "^13.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
